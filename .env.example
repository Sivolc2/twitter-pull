# Copy this file to .env and fill in your keys
# .env is gitignored and never committed

# ─── REQUIRED ─────────────────────────────────────────────────────────────────

# Twitter data — get free credits at https://getxapi.com (~$1.50/month for typical use)
GETXAPI_KEY=your-getxapi-key-here

# ─── OPTIONAL ─────────────────────────────────────────────────────────────────

# AI summarization — get at https://console.anthropic.com
# Without this, digests show top tweets ranked by engagement (still useful)
ANTHROPIC_API_KEY=your-anthropic-key-here

# Alternatives to GetXAPI (set fetcher in config/settings.yaml to switch)
TWITTERAPI_IO_KEY=your-twitterapi-io-key-here
