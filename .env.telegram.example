# Telegram configuration for sending digests
# Copy this file to .env.telegram and fill in your values

# Your personal Telegram chat ID for DMs
# Find this in your openclaw config or by messaging your bot
TELEGRAM_CHAT_ID=your-chat-id-here

# Telegram bot token (if not using from openclaw config)
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here

# OpenClaw configuration
OPENCLAW_BASE_URL=http://localhost:18789
OPENCLAW_SESSION=main
